{
  "name": "plataforma-automacao-comercial",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma multi-tenant de automacao comercial orientada a eventos.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:create": "node scripts/create-database.mjs",
    "db:migrate": "node scripts/apply-migrations.mjs",
    "smoke:message": "tsx --env-file=.env scripts/smoke-message.mjs",
    "dev:api": "tsx apps/api/src/server.ts",
    "dev:worker": "tsx apps/api/src/worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.104.0",
    "pg": "^8.13.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
